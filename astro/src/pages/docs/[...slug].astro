---
import { getCollection } from "astro:content";
import DocumentLayout from "@layouts/document-layout.astro";
import Img from "@components/img.mdx.astro";
import Message from "@components/message.mdx.astro";

export async function getStaticPaths() {
  try {
    const documents = await getCollection("docs");
    return documents.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
  } catch (error) {
    console.error("Error generating blog paths:", error);
    return [];
  }
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Custom components to override default HTML elements in MDX
const components = {
  img: Img,
  message: Message,
};
---

<DocumentLayout title={entry.data.title} headings={headings}>
  <article class="document">
    <header class="document-header">
      <h1>{entry.data.title}</h1>
    </header>
    <div class="document-content">
      <Content components={components} />
    </div>
  </article>
</DocumentLayout>
