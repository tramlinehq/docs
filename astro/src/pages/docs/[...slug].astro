const { entry } = Astro.props;
const { Content, headings } = await entry.render();
---

<DocumentLayout title={entry.data.title} headings={headings}>
  <article class="document">
    <header class="document-header">
      <h1>{entry.data.title}</h1>
    </header>
    <div class="document-content">
      <Content />
    </div>
  </article>
</DocumentLayout>

<style>
  .document {
    max-width: 100%;
  }

  .document-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
  }

  .document-header h1 {
    margin: 0;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text, #333);
  }

  .document-content {
    line-height: 1.6;
    color: var(--color-text, #333);
  }

  .document-content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.75rem;
    font-weight: 600;
  }

  .document-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .document-content :global(p) {
    margin-bottom: 1rem;
  }

  .document-content :global(a) {
    color: var(--color-link, #0066cc);
    text-decoration: none;
  }

  .document-content :global(a:hover) {
    text-decoration: underline;
  }

  .document-content :global(code) {
    background-color: var(--color-code-bg, #f5f5f5);
    padding: 0.2em 0.4em;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.9em;
  }

  .document-content :global(pre) {
    background-color: var(--color-code-bg, #f5f5f5);
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .document-content :global(pre code) {
    background-color: transparent;
    padding: 0;
  }

  .document-content :global(ul),
  .document-content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 2rem;
  }

  .document-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .document-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1rem 0;
  }

  .document-content :global(blockquote) {
    border-left: 4px solid var(--color-border, #e0e0e0);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted, #666);
    font-style: italic;
  }

  @media (prefers-color-scheme: dark) {
    .document-header h1 {
      color: var(--color-text, #e0e0e0);
    }

    .document-content {
      color: var(--color-text, #e0e0e0);
    }

    .document-content :global(code) {
      background-color: var(--color-code-bg, #2a2a2a);
    }

    .document-content :global(pre) {
      background-color: var(--color-code-bg, #2a2a2a);
    }

    .document-content :global(blockquote) {
      color: var(--color-text-muted, #999);
    }
  }
</style>
