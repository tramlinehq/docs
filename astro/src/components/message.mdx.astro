        />
      ) : (
        <path
          d="M0.877075 7.49988C0.877075 3.84219 3.84222 0.877045 7.49991 0.877045C11.1576 0.877045 14.1227 3.84219 14.1227 7.49988C14.1227 11.1575 11.1576 14.1227 7.49991 14.1227C3.84222 14.1227 0.877075 11.1575 0.877075 7.49988ZM7.49991 1.82704C4.36689 1.82704 1.82707 4.36686 1.82707 7.49988C1.82707 10.6329 4.36689 13.1727 7.49991 13.1727C10.6329 13.1727 13.1727 10.6329 13.1727 7.49988C13.1727 4.36686 10.6329 1.82704 7.49991 1.82704ZM9.85358 5.14644C10.0488 5.3417 10.0488 5.65829 9.85358 5.85355L8.20713 7.49999L9.85358 9.14644C10.0488 9.3417 10.0488 9.65829 9.85358 9.85355C9.65832 10.0488 9.34173 10.0488 9.14647 9.85355L7.50002 8.2071L5.85358 9.85355C5.65832 10.0488 5.34173 10.0488 5.14647 9.85355C4.95121 9.65829 4.95121 9.3417 5.14647 9.14644L6.79292 7.49999L5.14647 5.85355C4.95121 5.65829 4.95121 5.3417 5.14647 5.14644C5.34173 4.95118 5.65832 4.95118 5.85358 5.14644L7.50002 6.79289L9.14647 5.14644C9.34173 4.95118 9.65832 4.95118 9.85358 5.14644Z"
          fill="currentColor"
          fill-rule="evenodd"
          clip-rule="evenodd"
        />
      )
    }
  </svg>
  <div class="message-content">
    <slot />
  </div>
</aside>

<style>
  .message {
    display: flex;
    gap: var(--spacing-2, 0.75rem);
    align-items: flex-start;
    padding: var(--spacing-2, 0.75rem) var(--spacing-3, 1rem);
    border-radius: 6px;
    margin: var(--spacing-3, 1.5rem) 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .message-icon {
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .message-content {
    flex: 1;
    min-width: 0;
  }

  .message-content :global(p) {
    margin: 0;
  }

  .message-content :global(p + p) {
    margin-top: var(--spacing-2, 0.75rem);
  }

  .message-content :global(a) {
    text-decoration: underline;
  }

  .message-content :global(code) {
    background-color: rgba(0, 0, 0, 0.05);
    padding: 0.125em 0.375em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  /* Note - Blue/Gray subtle */
  .message-note {
    background-color: rgba(142, 142, 160, 0.14);
    color: var(--palette-gray-100, #3e3e43);
  }

  .message-note .message-icon {
    color: var(--palette-gray-300, #8e8ea0);
  }

  /* Tip - Green subtle */
  .message-tip {
    background-color: rgba(34, 197, 94, 0.1);
    color: #166534;
  }

  .message-tip .message-icon {
    color: #22c55e;
  }

  /* Info - Blue subtle */
  .message-info {
    background-color: rgba(250, 207, 133, 0.4);
    color: rgba(97, 63, 5, 1);
  }

  .message-info .message-icon {
    color: rgba(245, 158, 11, 1);
  }

  /* Warning - Orange subtle */
  .message-warning {
    background-color: rgba(245, 158, 11, 0.1);
    color: #92400e;
  }

  .message-warning .message-icon {
    color: #f59e0b;
  }

  /* Critical - Red subtle */
  .message-critical {
    background-color: rgba(239, 68, 68, 0.1);
    color: #991b1b;
  }

  .message-critical .message-icon {
    color: #ef4444;
  }

  @media (prefers-color-scheme: dark) {
    /* Note - Blue/Gray for dark mode */
    .message-note {
      background-color: rgba(142, 142, 160, 0.2);
      color: #d4d4d8;
    }

    .message-note .message-icon {
      color: #a1a1aa;
    }

    .message-note .message-content :global(code) {
      background-color: rgba(0, 0, 0, 0.3);
    }

    /* Tip - Green for dark mode */
    .message-tip {
      background-color: rgba(34, 197, 94, 0.15);
      color: #86efac;
    }

    .message-tip .message-icon {
      color: #4ade80;
    }

    .message-tip .message-content :global(code) {
      background-color: rgba(0, 0, 0, 0.3);
    }

    /* Info - Blue for dark mode */
    .message-info {
      background-color: rgba(250, 207, 133, 0.2);
      color: #fde68a;
    }

    .message-info .message-icon {
      color: #fbbf24;
    }

    .message-info .message-content :global(code) {
      background-color: rgba(0, 0, 0, 0.3);
    }

    /* Warning - Orange for dark mode */
    .message-warning {
      background-color: rgba(245, 158, 11, 0.15);
      color: #fcd34d;
    }

    .message-warning .message-icon {
      color: #fbbf24;
    }

    .message-warning .message-content :global(code) {
      background-color: rgba(0, 0, 0, 0.3);
    }

    /* Critical - Red for dark mode */
    .message-critical {
      background-color: rgba(239, 68, 68, 0.15);
      color: #fca5a5;
    }

    .message-critical .message-icon {
      color: #f87171;
    }

    .message-critical .message-content :global(code) {
      background-color: rgba(0, 0, 0, 0.3);
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .message {
      padding: var(--spacing-2, 0.75rem);
      margin: var(--spacing-2, 1rem) 0;
      font-size: 0.875rem;
    }
  }
</style>
