---
import { getCollection } from "astro:content";
import DocumentLayout from "@layouts/document-layout.astro";
import Img from "@components/img.mdx.astro";
import Message from "@components/message.mdx.astro";

export async function getStaticPaths() {
  try {
    const documents = await getCollection("integrations");
    return documents.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
  } catch (error) {
    console.error("Error generating integrations paths:", error);
    return [];
  }
}

