---
import { getCollection } from "astro:content";

// Get current path for active state highlighting
const currentPath = Astro.url.pathname;

// Fetch all documents from the content collection
const allDocuments = await getCollection("document");

// Helper function to read category metadata
function getCategoryInfo(slug: string) {
  const parts = slug.split("/");
  if (parts.length > 1) {
    return parts[0];
  }
  return null;
}

// Group documents by category
const categories = new Map<string, any[]>();
const rootDocs: any[] = [];

for (const doc of allDocuments) {
  const category = getCategoryInfo(doc.id);

  if (category) {
    if (!categories.has(category)) {
      categories.set(category, []);
    }
    categories.get(category)!.push(doc);
  } else {
    rootDocs.push(doc);
  }
}

// Sort documents by sidebar_position if available
function sortDocs(docs: any[]) {
  return docs.sort((a, b) => {
    const posA = a.data.sidebar_position ?? 999;
    const posB = b.data.sidebar_position ?? 999;
    return posA - posB;
  });
}

// Sort root docs
const sortedRootDocs = sortDocs(rootDocs);

// Sort each category's docs
const sortedCategories = new Map<string, any[]>();
for (const [key, docs] of categories.entries()) {
  sortedCategories.set(key, sortDocs(docs));
}

// Category labels mapping
const categoryLabels: Record<string, string> = {
  "getting-started": "🚀 Getting Started",
  "using-tramline": "📱 Using Tramline",
  integrations: "🔌 Integrations",
};

function getCategoryLabel(slug: string): string {
  return (
    categoryLabels[slug] ||
    slug.replace(/-/g, " ").replace(/\b\w/g, (l) => l.toUpperCase())
  );
}

function getDocUrl(doc: any): string {
  // Check if doc has a custom slug in frontmatter
  if (doc.data.slug) {
    return doc.data.slug;
  }
  // Otherwise use the id to construct the URL
  return `/${doc.id}`;
}

function getDocLabel(doc: any): string {
  return doc.data.title;
}

// Helper to check if a link is active
function isActivePath(docUrl: string): boolean {
  // Normalize paths for comparison
  const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
  const normalizedDoc = docUrl.replace(/\/$/, '') || '/';
  return normalizedCurrent === normalizedDoc;
}

// Helper to check if a category has an active page
function categoryHasActivePage(docs: any[]): boolean {
  return docs.some((doc) => isActivePath(getDocUrl(doc)));
}
---

<nav class="primary-nav" aria-label="Primary navigation">
  <ul class="nav-list">
    {
      sortedRootDocs.map((doc) => {
        const url = getDocUrl(doc);
        const isActive = isActivePath(url);
        return (
          <li class="nav-item">
            <a
              href={url}
              class:list={["nav-link", { active: isActive }]}
              aria-current={isActive ? "page" : undefined}
            >
              {getDocLabel(doc)}
            </a>
          </li>
        );
      })
    }

    {
      Array.from(sortedCategories.entries()).map(([categorySlug, docs]) => {
        const hasActivePage = categoryHasActivePage(docs);
        return (
          <li class="nav-category">
            <div
              class:list={["category-label", { "has-active": hasActivePage }]}
            >
              {getCategoryLabel(categorySlug)}
            </div>
            <ul class="nav-sublist">
              {docs.map((doc) => {
                const url = getDocUrl(doc);
                const isActive = isActivePath(url);
                return (
                  <li class="nav-item">
                    <a
                      href={url}
                      class:list={["nav-link", { active: isActive }]}
                      aria-current={isActive ? "page" : undefined}
                    >
                      {getDocLabel(doc)}
                    </a>
                  </li>
                );
              })}
            </ul>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .primary-nav {
    width: 250px;
    padding: 1rem;
    background-color: var(--color-bg-nav, #f5f5f5);
    border-right: 1px solid var(--color-border, #e0e0e0);
    overflow-y: auto;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    margin: 0;
  }

  .nav-link {
    display: block;
    padding: 0.5rem 0.75rem;
    color: var(--color-text, #333);
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.2s ease;
    position: relative;
  }

  .nav-link:hover {
    background-color: var(--color-bg-hover, #e8e8e8);
  }

  /* Active page styles */
  .nav-link.active {
    background-color: var(--color-primary, #0066cc);
    color: var(--color-white, #ffffff);
    font-weight: 600;
  }

  .nav-link.active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 70%;
    background-color: var(--color-white, #ffffff);
    border-radius: 0 2px 2px 0;
  }

  .nav-link.active:hover {
    background-color: var(--color-primary-dark, #0052a3);
  }

  .nav-category {
    margin-top: 1.5rem;
  }

  .nav-category:first-child {
    margin-top: 0;
  }

  .category-label {
    font-weight: 700;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted, #666);
    padding: 0.5rem 0.75rem;
    margin-bottom: 0.25rem;
    transition: color 0.2s ease;
  }

  /* Highlight category when it has an active page */
  .category-label.has-active {
    color: var(--color-primary, #0066cc);
  }

  .nav-sublist {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (prefers-color-scheme: dark) {
    .primary-nav {
      background-color: var(--color-bg-nav, #1a1a1a);
      border-right-color: var(--color-border, #333);
    }

    .nav-link {
      color: var(--color-text, #e0e0e0);
    }

    .nav-link:hover {
      background-color: var(--color-bg-hover, #2a2a2a);
    }

    .nav-link.active {
      background-color: var(--color-primary, #0066cc);
      color: var(--color-white, #ffffff);
    }

    .nav-link.active::before {
      background-color: var(--color-white, #ffffff);
    }

    .category-label {
      color: var(--color-text-muted, #999);
    }

    .category-label.has-active {
      color: var(--color-primary-light, #3399ff);
    }
  }

  /* Smooth scrolling to active item */
  @media (prefers-reduced-motion: no-preference) {
    .nav-link {
      scroll-margin-top: 2rem;
    }
  }
</style>

<script>
  // Scroll active link into view on page load
  document.addEventListener("DOMContentLoaded", () => {
    const activeLink = document.querySelector(
      ".primary-nav .nav-link.active"
    ) as HTMLElement;
    if (activeLink) {
      activeLink.scrollIntoView({
        behavior: "smooth",
        block: "center",
      });
    }
  });
</script>
